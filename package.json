{"name": "coding-agent-web-template", "private": true, "version": "0.0.0", "type": "module", "scripts": {"lint": "node scripts/lint.mjs", "start": "node apps/server/dist/index.js", "test": "vitest run", "test:infra": "vitest run --project=server apps/server/_test/infra", "test:integration": "vitest run --project=server apps/server/__tests__", "test:client": "vitest run --project=client", "check:contract": "node scripts/check-agents-contract.mjs", "build": "pnpm --filter client run build"}, "workspaces": ["apps/*", "packages/*"], "devDependencies": {"@types/react": "^19.2.17", "@types/react-dom": "^19.2.3", "react": "^19.2.7", "react-dom": "^19.2.7", "typescript": "^5.5.3", "vite": "npm:rolldown-vite@^7.3.1", "vitest": "^4.1.8"}}